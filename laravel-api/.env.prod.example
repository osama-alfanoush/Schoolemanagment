APP_NAME="School Suite"
APP_ENV=production
APP_DEBUG=false
APP_KEY=GENERATE_WITH_ARTISAN
# Always use HTTPS in production (terminate TLS at NGINX / a load balancer).
APP_URL=https://YOUR_DOMAIN
APP_VERSION=1.0.0

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=school_prod
DB_USERNAME=school
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

SESSION_DRIVER=redis
SESSION_LIFETIME=480
# Secure cookies require HTTPS — keep true in production.
SESSION_SECURE_COOKIE=true
CACHE_STORE=redis
QUEUE_CONNECTION=redis

# --- Auth / CORS -----------------------------------------------------------
# Comma-separated origins allowed to call the API from a browser.
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN
# Stateless Bearer-token API — statefulApi() is disabled in bootstrap/app.php,
# so SANCTUM_STATEFUL_DOMAINS is unused. Left commented for reference only.
# SANCTUM_STATEFUL_DOMAINS=YOUR_DOMAIN
# Access-token TTL in minutes (refresh tokens rotate separately).
SANCTUM_TOKEN_TTL=120

# --- Payments (Stripe) -----------------------------------------------------
PAYMENT_PROVIDER=stripe
PAYMENT_CURRENCY=usd
STRIPE_SECRET_KEY=CHANGE_THIS_STRIPE_SECRET_KEY
STRIPE_PUBLIC_KEY=CHANGE_THIS_STRIPE_PUBLIC_KEY
STRIPE_WEBHOOK_SECRET=CHANGE_THIS_STRIPE_WEBHOOK_SECRET

# --- Mail ------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_THIS_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=CHANGE_THIS_SMTP_USER
MAIL_PASSWORD=CHANGE_THIS_SMTP_PASSWORD
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS="noreply@YOUR_DOMAIN"
MAIL_FROM_NAME="${APP_NAME}"

# --- Object storage (MinIO / S3) -------------------------------------------
# Set FILESYSTEM_DISK=s3 to store uploads in object storage instead of local.
FILESYSTEM_DISK=local
MINIO_KEY=CHANGE_THIS_MINIO_KEY
MINIO_SECRET=CHANGE_THIS_MINIO_SECRET
AWS_ACCESS_KEY_ID="${MINIO_KEY}"
AWS_SECRET_ACCESS_KEY="${MINIO_SECRET}"
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=school-uploads
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# --- Push notifications ----------------------------------------------------
FCM_SERVER_KEY=

# --- Observability ---------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
AUDIT_LOG_CHANNEL=daily
AUDIT_RETENTION_DAYS=90

LOG_CHANNEL=stack
LOG_LEVEL=error
