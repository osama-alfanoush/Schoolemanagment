# ── Build ──────────────────────────────────────────────────────────────
PORT=5173                         # Dev/preview server port
BASE_PATH=/                       # App base path (e.g. /school-web/ behind a reverse proxy)
VITE_API_BASE_URL=/api            # API base URL (set to full URL in production: https://api.example.com/api)

# ── Optional (defaults are safe) ──────────────────────────────────────
# VITE_API_TIMEOUT_MS=15000       # Request timeout in milliseconds
